# Required for transcription. If missing, uploads return a generic error.
OPENAI_API_KEY=
# Optional. If set, jobs are queued (requires a separate worker process). If unset, transcription runs inline in the API so uploads work without Redis or a worker.
REDIS_URL=
UPLOAD_DIR=/tmp/transcriber-uploads
CHUNK_TARGET_MB=20
MAX_UPLOAD_MB=200
WORKER_CONCURRENCY=2
