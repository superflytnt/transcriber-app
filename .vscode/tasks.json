{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Transcriber and show in browser",
      "type": "shell",
      "command": "./scripts/show-local.sh",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "silent", "echo": true },
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "label": "Open Transcriber (local) in Simple Browser",
      "type": "shell",
      "command": "echo",
      "args": ["${input:openTranscriberLocal}"],
      "problemMatcher": [],
      "presentation": { "reveal": "never", "echo": false }
    },
    {
      "label": "Open Transcriber (Railway) in Simple Browser",
      "type": "shell",
      "command": "echo",
      "args": ["${input:openTranscriberBrowser}"],
      "problemMatcher": [],
      "presentation": { "reveal": "never", "echo": false }
    }
  ],
  "inputs": [
    {
      "id": "openTranscriberLocal",
      "type": "command",
      "command": "simpleBrowser.show",
      "args": ["http://localhost:3000"]
    },
    {
      "id": "openTranscriberBrowser",
      "type": "command",
      "command": "simpleBrowser.show",
      "args": ["https://transcriber2-production.up.railway.app"]
    }
  ]
}
